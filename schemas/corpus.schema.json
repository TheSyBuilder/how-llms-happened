{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LLM Lineage corpus",
  "description": "The source-backed works, ideas, claims, relationships, and learning objectives used by LLM Lineage.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "corpusId",
    "title",
    "description",
    "asOf",
    "orderingPolicy",
    "works",
    "ideas",
    "sources",
    "claims",
    "relationships",
    "learningObjectives"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "corpusId": {
      "$ref": "#/$defs/id"
    },
    "title": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "description": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "asOf": {
      "$ref": "#/$defs/fullDate"
    },
    "orderingPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description",
        "tieBreak"
      ],
      "properties": {
        "description": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "tieBreak": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "works": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/work"
      }
    },
    "ideas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/idea"
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source"
      }
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/claim"
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/relationship"
      }
    },
    "learningObjectives": {
      "type": "array",
      "minItems": 2,
      "items": {
        "$ref": "#/$defs/learningObjective"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "fullDate": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "date": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "precision",
        "calendar"
      ],
      "properties": {
        "value": {
          "type": "string"
        },
        "precision": {
          "type": "string",
          "enum": [
            "year",
            "month",
            "day"
          ]
        },
        "calendar": {
          "type": "string",
          "enum": [
            "gregorian",
            "julian",
            "source-as-printed"
          ]
        },
        "note": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "oneOf": [
        {
          "properties": {
            "precision": {
              "const": "year"
            },
            "value": {
              "pattern": "^\\d{4}$"
            }
          }
        },
        {
          "properties": {
            "precision": {
              "const": "month"
            },
            "value": {
              "pattern": "^\\d{4}-\\d{2}$"
            }
          }
        },
        {
          "properties": {
            "precision": {
              "const": "day"
            },
            "value": {
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            }
          }
        }
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "calendar": {
                "const": "source-as-printed"
              }
            }
          },
          "then": {
            "required": [
              "note"
            ]
          }
        }
      ]
    },
    "uncertainty": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "note"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "open",
            "disputed",
            "resolved"
          ]
        },
        "note": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "resolutionCondition": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "identifier": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "value"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "doi",
            "isbn",
            "report-number",
            "catalog-id"
          ]
        },
        "value": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "label": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "versionBibliography": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "citation",
        "venue",
        "identifiers"
      ],
      "properties": {
        "citation": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "venue": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "volume": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "issues": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "pages": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "identifiers": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        }
      }
    },
    "dateEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceId",
        "precision",
        "locator"
      ],
      "properties": {
        "sourceId": {
          "$ref": "#/$defs/id"
        },
        "precision": {
          "type": "string",
          "enum": [
            "year",
            "month",
            "day"
          ]
        },
        "locator": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "chronologyEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "label",
        "date",
        "dateEvidence",
        "versionId",
        "sourceIds"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "kind": {
          "type": "string",
          "enum": [
            "lecture",
            "manuscript-received",
            "journal-publication",
            "online-publication",
            "translation-publication",
            "preprint",
            "conference-presentation",
            "technical-report"
          ]
        },
        "label": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "date": {
          "$ref": "#/$defs/date"
        },
        "dateEvidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/dateEvidence"
          }
        },
        "versionId": {
          "$ref": "#/$defs/id"
        },
        "sourceIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/id"
          }
        }
      }
    },
    "version": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "label",
        "language",
        "bibliography",
        "sourceIds",
        "notes"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "kind": {
          "type": "string",
          "enum": [
            "original",
            "translation",
            "corrected-reprint",
            "preprint",
            "proceedings",
            "journal"
          ]
        },
        "label": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "language": {
          "type": "string",
          "pattern": "^[a-z]{2,3}$"
        },
        "bibliography": {
          "$ref": "#/$defs/versionBibliography"
        },
        "sourceIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "notes": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "work": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "authors",
        "artifactType",
        "displayCitation",
        "chronology",
        "versions",
        "canonicalVersionId",
        "preferredSourceIds",
        "sourceIds",
        "inclusion",
        "ideaIds",
        "significance",
        "limitations",
        "uncertainties"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "authors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "artifactType": {
          "type": "string",
          "enum": [
            "lecture",
            "journal-article",
            "conference-paper",
            "technical-report",
            "book",
            "dataset",
            "implementation"
          ]
        },
        "displayCitation": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "chronology": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "orderingEventId",
            "events"
          ],
          "properties": {
            "orderingEventId": {
              "$ref": "#/$defs/id"
            },
            "events": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/chronologyEvent"
              }
            }
          }
        },
        "versions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/version"
          }
        },
        "canonicalVersionId": {
          "$ref": "#/$defs/id"
        },
        "preferredSourceIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "sourceIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "inclusion": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "confidence",
            "rationale"
          ],
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "core",
                "branch",
                "prologue",
                "context",
                "candidate",
                "excluded"
              ]
            },
            "confidence": {
              "$ref": "#/$defs/confidence"
            },
            "rationale": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "exclusionRationale": {
              "$ref": "#/$defs/nonEmptyString"
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "status": {
                    "const": "excluded"
                  }
                }
              },
              "then": {
                "required": [
                  "exclusionRationale"
                ]
              }
            }
          ]
        },
        "ideaIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "significance": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "beginner",
            "expert"
          ],
          "properties": {
            "beginner": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "expert": {
              "$ref": "#/$defs/nonEmptyString"
            }
          }
        },
        "limitations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "uncertainties": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/uncertainty"
          }
        }
      }
    },
    "idea": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "kind",
        "description",
        "claimIds",
        "uncertainties"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "kind": {
          "type": "string",
          "enum": [
            "mechanism",
            "objective",
            "finding",
            "problem",
            "constraint",
            "formalism"
          ]
        },
        "description": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "claimIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "uncertainties": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/uncertainty"
          }
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "relatedWorkIds",
        "title",
        "url",
        "accessDate",
        "sourceClass",
        "authority",
        "versionIds",
        "supports",
        "accessNote"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "relatedWorkIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "url": {
          "type": "string",
          "pattern": "^https://[A-Za-z0-9](?:[A-Za-z0-9.-]*[A-Za-z0-9])?(?::[0-9]+)?(?:[/?#][^\\s]*)?$"
        },
        "accessDate": {
          "$ref": "#/$defs/fullDate"
        },
        "sourceClass": {
          "type": "string",
          "enum": [
            "publisher-record",
            "official-record",
            "primary-full-text",
            "scholarly-translation",
            "scholarly-history",
            "corrected-reprint",
            "institutional-archive"
          ]
        },
        "authority": {
          "type": "string",
          "enum": [
            "publisher",
            "author",
            "institutional-repository",
            "institutional-host",
            "public-archive",
            "scholarly-edition"
          ]
        },
        "versionIds": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "supports": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "metadata",
              "full-text",
              "claim-location"
            ]
          }
        },
        "pagination": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "scheme",
            "pageStart",
            "pageEnd"
          ],
          "properties": {
            "scheme": {
              "type": "string",
              "enum": [
                "printed",
                "reprint",
                "article"
              ]
            },
            "pageStart": {
              "type": "integer",
              "minimum": 1
            },
            "pageEnd": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "accessNote": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "supports": {
                "contains": {
                  "const": "claim-location"
                }
              }
            }
          },
          "then": {
            "required": [
              "pagination"
            ]
          }
        }
      ]
    },
    "locator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label"
      ],
      "properties": {
        "label": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "section": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "pageStart": {
          "type": "integer",
          "minimum": 1
        },
        "pageEnd": {
          "type": "integer",
          "minimum": 1
        },
        "figure": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "table": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "equation": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "paragraph": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "anyOf": [
        {
          "required": [
            "section"
          ]
        },
        {
          "required": [
            "pageStart"
          ]
        },
        {
          "required": [
            "figure"
          ]
        },
        {
          "required": [
            "table"
          ]
        },
        {
          "required": [
            "equation"
          ]
        },
        {
          "required": [
            "paragraph"
          ]
        }
      ],
      "allOf": [
        {
          "if": {
            "required": [
              "pageEnd"
            ]
          },
          "then": {
            "required": [
              "pageStart"
            ]
          }
        }
      ]
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceId",
        "locator",
        "support"
      ],
      "properties": {
        "sourceId": {
          "$ref": "#/$defs/id"
        },
        "locator": {
          "$ref": "#/$defs/locator"
        },
        "support": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "priorityReview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operationalDefinition",
        "searchScope",
        "sourceIds"
      ],
      "properties": {
        "operationalDefinition": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "searchScope": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "sourceIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/id"
          }
        }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "workId",
        "ideaIds",
        "statement",
        "directness",
        "confidence",
        "evidence",
        "limitations",
        "uncertainties",
        "checkedDate"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "workId": {
          "$ref": "#/$defs/id"
        },
        "ideaIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "statement": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "directness": {
          "type": "string",
          "enum": [
            "direct",
            "editorial-inference"
          ]
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidence"
          }
        },
        "limitations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "uncertainties": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/uncertainty"
          }
        },
        "checkedDate": {
          "$ref": "#/$defs/fullDate"
        },
        "priorityReview": {
          "$ref": "#/$defs/priorityReview"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "statement": {
                "pattern": "\\b((?:[Tt]he|[Aa]) [Ff]irst|[Ff]irst[- ](?:paper|study|model|method|system|use|demonstration)|[Ee]arliest|[Ii]nvented|[Ii]nvention|[Oo]riginated|[Oo]riginator|[Pp]ioneered|[Ss]olved|[Pp]roved|[Ii]ntroduced|[Cc]reated|[Dd]iscovered|[Cc]oined)\\b"
              }
            }
          },
          "then": {
            "required": [
              "priorityReview"
            ]
          }
        }
      ]
    },
    "nodeRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "work",
            "idea"
          ]
        },
        "id": {
          "$ref": "#/$defs/id"
        }
      }
    },
    "relationship": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "from",
        "to",
        "connectionType",
        "evidenceClass",
        "confidence",
        "rationale",
        "claimIds",
        "sourceEvidence",
        "causalLanguage",
        "uncertainties"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "from": {
          "$ref": "#/$defs/nodeRef"
        },
        "to": {
          "$ref": "#/$defs/nodeRef"
        },
        "connectionType": {
          "type": "string",
          "enum": [
            "builds-on",
            "extends",
            "combines",
            "challenges",
            "makes-practical",
            "enables",
            "conceptual-parallel"
          ]
        },
        "evidenceClass": {
          "type": "string",
          "enum": [
            "documented-influence",
            "inherited-mechanism",
            "editorial-synthesis"
          ]
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "rationale": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "claimIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "sourceEvidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence"
          }
        },
        "causalLanguage": {
          "type": "string",
          "enum": [
            "qualified",
            "prohibited"
          ]
        },
        "uncertainties": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/uncertainty"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "evidenceClass": {
                "const": "documented-influence"
              }
            }
          },
          "then": {
            "properties": {
              "sourceEvidence": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "causalLanguage": {
                "const": "qualified"
              }
            }
          },
          "then": {
            "properties": {
              "evidenceClass": {
                "const": "documented-influence"
              },
              "sourceEvidence": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "connectionType": {
                "const": "conceptual-parallel"
              }
            }
          },
          "then": {
            "properties": {
              "evidenceClass": {
                "enum": [
                  "inherited-mechanism",
                  "editorial-synthesis"
                ]
              },
              "causalLanguage": {
                "const": "prohibited"
              }
            }
          }
        }
      ]
    },
    "learningObjective": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "mode",
        "objective",
        "workIds",
        "ideaIds",
        "claimIds",
        "prerequisites",
        "successCriterion"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "mode": {
          "type": "string",
          "enum": [
            "beginner",
            "expert"
          ]
        },
        "objective": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "workIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "ideaIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "claimIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "prerequisites": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "successCriterion": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    }
  }
}
